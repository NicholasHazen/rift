# Canonical block: github/gitignore UnrealEngine.gitignore, verbatim — keep it
# byte-identical to upstream so future diffs stay one command. Local edits go
# below the "Local additions" marker only. Project lives at repo root.

# Visual Studio 2015 user specific files
.vs/

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
.vsconfig

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Binary Files
Binaries/*
Plugins/**/Binaries/*

# Builds
Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
Saved/*

# Compiled source files for the engine to use
Intermediate/*
Plugins/**/Intermediate/*

# Cache files for the editor to use
DerivedDataCache/*

# --- Local additions (macOS · Rider · agent tooling) — everything below is ours ---

# macOS
.DS_Store

# JetBrains Rider
.idea/
*.DotSettings.user
# RiderLink installs into the project as full plugin source if you pick
# "install to game project" — keep it out either way (engine-install preferred)
Plugins/Developer/RiderLink/

# VS Code workspace state (policy: agent-scratch only; revisit if shared config wanted)
.vscode/

# Claude Code machine-local permissions
.claude/settings.local.json

# clangd database + index cache (regenerate: UnrealBuildTool -Mode=GenerateClangDatabase)
compile_commands.json
.cache/
